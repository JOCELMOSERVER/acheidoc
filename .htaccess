Options -Indexes
RewriteEngine On

# Redirecionar /agente para o login
RewriteRule ^agente/?$ /agente/login.html [R=301,L]
RewriteRule ^admin/?$ /admin/login.html [R=301,L]

# SPA fallback — serve index.html para rotas não encontradas (excepto assets)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(?!api/)(.*)$ /index.html [L]
